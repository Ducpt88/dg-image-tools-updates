# Copy to server/.env for local packaged/admin runs. Do not commit real secrets.

# Required for first-time local admin seeding. Existing databases keep their users.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-before-release

# Optional legacy fallback. Leave empty unless you intentionally want built-in admin accounts seeded.
DEFAULT_ADMIN_PASSWORD=

# Local JSON database directory. Leave empty to use Electron userData/data in packaged app.
DATA_DIR=

# Backend server image provider. Production should not use trycloudflare tunnels.
ROUTER_PROVIDER=openai
ROUTER_IMAGE_ENDPOINT=https://api.openai.com/v1/images/generations
ROUTER_IMAGE_PREFERRED_ENDPOINT=primary-openai
ROUTER_IMAGE_FALLBACK_ENDPOINT=
ROUTER_IMAGE_MODEL=gpt-image-1
ROUTER_API_KEY=replace-with-server-side-provider-key
ROUTER_PROXY_API_KEY=replace-with-proxy-access-key-if-different
OPENAI_API_KEY=replace-with-openai-key
VPS_ROUTER_API_KEY=replace-with-vps-9router-key
EMERGENCY_ROUTER_API_KEY=replace-with-emergency-tunnel-key
ROUTER_IMAGE_TARGETS_JSON=[{"name":"primary-openai","provider":"openai","url":"https://api.openai.com/v1/images/generations","model":"gpt-image-1","keyEnv":"OPENAI_API_KEY"},{"name":"fallback-vps-9router","provider":"9router","url":"https://backup-vps.example.com/v1/images/generations","model":"cx/gpt-5.5-image","keyEnv":"VPS_ROUTER_API_KEY"},{"name":"emergency-local-tunnel","provider":"9router","url":"https://replace-current-tunnel.trycloudflare.com/v1/images/generations","model":"cx/gpt-5.5-image","keyEnv":"EMERGENCY_ROUTER_API_KEY"}]
ROUTER_QUOTA_ENDPOINT=
ROUTER_QUOTA_TOTAL=

# Desktop app endpoints.
NINE_ROUTER_API_BASE_URL=https://api.ducpt.com
LOCAL_ROUTER_BASE_URL=http://localhost:20128
LOCAL_ROUTER_IMAGE_ENDPOINT=http://localhost:20128/v1/images/generations
# Customer User builds should use the cloud backend by default. Enable only for an internal/local-only deployment.
ALLOW_USER_LOCAL_LOGIN=false

# Optional security alert webhook.
SECURITY_ALERT_WEBHOOK_URL=

# Central update policy server. Set this on customer apps when using your own backend.
UPDATE_POLICY_URL=https://api.ducpt.com/api/9router/update-policy
UPDATE_POLICY_ADMIN_URL=https://api.ducpt.com/api/9router/admin/update-policy

# Required by server/index.js for PUT /api/9router/admin/update-policy.
UPDATE_ADMIN_TOKEN=change-this-long-random-token
