{
  "name": "9router-electron-tool",
  "version": "1.9.1",
  "description": "Desktop Electron tool scaffold for 9router.",
  "main": "src/main.js",
  "scripts": {
    "start": "node scripts/run-electron.js",
    "smoke": "node scripts/run-electron.js --smoke-test",
    "server": "node server/index.js",
    "dist": "electron-builder --win nsis",
    "dist:user": "electron-builder --win nsis -c.appId=com.9router.image-tool.user -c.productName=\"DG Image Tools user 1.9\" -c.nsis.shortcutName=\"DG Image Tools user 1.9\" -c.nsis.artifactName=\"DG Image Tools user 1.9-Setup-${arch}.${ext}\"",
    "dist:user:publish": "electron-builder --win nsis --publish always -c.appId=com.9router.image-tool.user -c.productName=\"DG Image Tools user 1.9\" -c.nsis.shortcutName=\"DG Image Tools user 1.9\" -c.nsis.artifactName=\"DG Image Tools user 1.9-Setup-${arch}.${ext}\"",
    "pack": "electron-builder --dir"
  },
  "keywords": [
    "electron",
    "desktop",
    "tool"
  ],
  "author": "9Router",
  "license": "MIT",
  "build": {
    "appId": "com.9router.image-tool.admin",
    "productName": "DG Image Tools Admin 1.9",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Ducpt88",
        "repo": "dg-image-tools-updates",
        "private": true
      }
    ],
    "files": [
      "src/**/*",
      "server/store.js",
      "package.json"
    ],
    "asar": true,
    "win": {
      "icon": "src/assets/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${arch}.${ext}",
      "installerIcon": "src/assets/icon.ico",
      "uninstallerIcon": "src/assets/icon.ico",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DG Image Tools Admin 1.9"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${arch}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.0.12"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3"
  }
}
